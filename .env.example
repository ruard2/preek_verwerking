# Kopieer dit bestand naar ".env" en vul je eigen sleutel in.
# .env wordt NIET meegecommit (staat in .gitignore).

# Verplicht: je OpenAI API-sleutel.
OPENAI_API_KEY=sk-...

# Lokaal: de PO-token-provider draait via Docker op deze poort.
# start.bat start die container automatisch. Laat dit zo staan.
POT_PROVIDER_URL=http://127.0.0.1:4416

# Optioneel: andere modellen.
# OPENAI_MODEL=gpt-5
# OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Voor GEHOST gebruik (bijv. Railway): Supadata haalt de YouTube-transcriptie
# op zonder dat het datacenter-IP geblokkeerd wordt. Zet je API-sleutel hier;
# dan gebruikt de app Supadata i.p.v. yt-dlp (en is de PO-token-provider en
# audio-transcriptie niet nodig). Lokaal laat je dit leeg.
# SUPADATA_API_KEY=sd_...

# Opslagmap voor de cache (dienstenlijst + verwerkte preken). Standaard ./data.
# Op Railway: koppel hier een volume aan zodat de cache een redeploy overleeft.
# DATA_DIR=/data
